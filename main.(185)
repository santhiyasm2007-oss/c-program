#include <stdio.h>

int main() {
    int n;
    scanf("%d", &n);

    int arr[n];
    int i = 0;
    while(i < n) {
        scanf("%d", &arr[i]);
        i++;
    }

    int index = 0;
    i = 0;
    while(i < n) {
        if(arr[i] != 0) {
            arr[index] = arr[i];
            index++;
        }
        i++;
    }
    while(index < n) {
        arr[index] = 0;
        index++;
    }
    i = 0;
    while(i < n) {
        printf("%d ", arr[i]);
        i++;
    }

    return 0;
}