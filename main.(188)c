#include <stdio.h>

int main()
{
    int n,i;
    scanf("%d",&n);
    int arr[n];

    for(i=0;i<n;i++){
        scanf("%d",&arr[i]);
    }
    int current=1,max=1;
    for(i=1;i<n;i++){
        if(arr[i] > arr[i-1]){
            current++;
            if(current > max){
                max = current;
            }
        }
        else{
            current = 1;
        }
    }
    printf("%d",max);
    return 0;
}