#include <stdio.h>

int main() 
{
    int n, i, day;
    int evenCount = 0, oddCount = 0;
    scanf("%d", &n);
    for(i = 1; i <= n; i++)
    {
        scanf("%d", &day);
        if(day % 2 == 0)
            evenCount++;
        else
            oddCount++;
    }
    printf("Even:%d Odd:%d", evenCount, oddCount);
    return 0;
}