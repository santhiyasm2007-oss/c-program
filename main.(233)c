#include <stdio.h>

int main() {
    char str[100];
    int i, count = 0;
    printf("Enter Product ID: ");
    scanf("%s", str);
    for(i = 0; str[i] != '\0'; i++) {
        if(str[i] >= '0' && str[i] <= '9') {
            count++;
        }
    }
    printf("Number of digits: %d", count);
    return 0;
}