#include <stdio.h>
#include <string.h>
#include <ctype.h>
int main()
{
    char password[100];
    int i, count = 0;
    printf("Enter Password: ");
    fgets(password, sizeof(password), stdin);
    for(i = 0; password[i] != '\0'; i++)
    {
        if(!isalnum(password[i]) && password[i] != '\n')
        {
            count++;
        }
    }
    printf("Special character count: %d", count);
    return 0;
}
