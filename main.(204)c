#include <stdio.h>
int main()
{
    int r, c;
    scanf("%d %d", &r, &c);
    int a[r][c];
    int i, j;
    for(i = 0; i < r; i++)
    {
        for(j = 0; j < c; j++)
        {
            scanf("%d", &a[i][j]);
        }
    }
    long long maxProduct = -9223372036854775807LL;
    int maxRow = 0;
    for(i = 0; i < r; i++)
    {
        long long product = 1;

        for(j = 0; j < c; j++)
        {
            product = product * a[i][j];
        }

        if(product > maxProduct)
        {
            maxProduct = product;
            maxRow = i;
        }
    }
    printf("%d", maxRow);
    return 0;
}