#include <stdio.h>

int main()
{
    int R, C;
    int a[100][100];
    int i, j, k;
    int count = 0;
    int flag;
    printf("Enter rows and columns: ");
    scanf("%d %d", &R, &C);

    for(i = 0; i < R; i++)
    {
        for(j = 0; j < C; j++)
        {
            scanf("%d", &a[i][j]);
        }
    }
    for(i = 0; i < R; i++)
    {
        flag = 1;
        for(j = 0, k = C - 1; j < k; j++, k--)
        {
            if(a[i][j] != a[i][k])
            {
                flag = 0;
                break;
            }
        }
        if(flag == 1)
        {
            count++;
        }
    }
    printf("%d", count);
    return 0;
}