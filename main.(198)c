#include <stdio.h>

int main()
{
    int r, c, a[50][50];
    scanf("%d %d", &r, &c);
    for(int i = 0; i < r; i++)
    {
        for(int j = 0; j < c; j++)
        {
            scanf("%d", &a[i][j]);
        }
    }
    for(int i = 0; i < r; i++)
    {
        for(int j = 0; j < c; j++)
        {
            for(int x = 0; x < r; x++)
            {
                for(int y = 0; y < c; y++)
                {
                    if(i != x || j != y)
                    {
                        if(a[i][j] == a[x][y])
                        {
                            printf("%d", a[i][j]);
                            return 0;
                        }
                    }
                }
            }
        }
    }

    return 0;
}